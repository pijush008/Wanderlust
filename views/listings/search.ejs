<% layout("layouts/boilerplate") %>

<div class="search-results-page">
  <div class="search-header mb-4">
    <h4>
      <i class="fa-solid fa-magnifying-glass me-2"></i>
      Search results for "<strong><%= query %></strong>"
    </h4>
    <p class="text-muted">
      <% if (results.length > 0) { %>
        Found <strong><%= results.length %></strong> listing<%= results.length > 1 ? 's' : '' %>
      <% } else { %>
        No results found
      <% } %>
    </p>
  </div>

  <% if (results.length === 0) { %>
    <div class="no-results text-center py-5">
      <i class="fa-solid fa-face-sad-tear" style="font-size: 4rem; color: #ccc;"></i>
      <h5 class="mt-3">No listings match your search</h5>
      <p class="text-muted">Try different keywords, check for typos, or browse all listings</p>
      <div class="mt-3">
        <a href="/listings" class="btn btn-outline-dark me-2">
          <i class="fa-solid fa-compass me-1"></i> Browse All
        </a>
      </div>
    </div>
  <% } else { %>
    <div class="row row-cols-lg-4 row-cols-md-3 row-cols-sm-1 g-3">
      <% for (let listing of results) { %>
        <div class="col">
          <a href="/listings/<%= listing._id %>" class="text-decoration-none text-dark">
            <div class="card col listing-card">
              <img
                src="<%= listing.image.url %>"
                class="card-img-top"
                alt="<%= listing.title %>"
                style="height: 20rem; object-fit: cover;"
                onerror="this.src='https://positiwise.com/blog/wp-content/uploads/2022/01/javascript-framework-2.jpg'"
              >
              <div class="card-body">
                <p class="card-text">
                  <strong><%= listing.title %></strong><br/>
                  <small class="text-muted">
                    <i class="fa-solid fa-location-dot"></i> <%= listing.location %>, <%= listing.country %>
                  </small><br/>
                  ₹<%= Number(listing.price).toLocaleString("en-IN") %>
                </p>
              </div>
            </div>
          </a>
        </div>
      <% } %>
    </div>
  <% } %>
</div>
