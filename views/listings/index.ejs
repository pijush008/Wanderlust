<% layout("layouts/boilerplate") %>

<style>
    #filters{

        display: flex;
        flex-wrap: wrap;
        align-items: center;
    }
    .filter{
        text-align: center;
        margin-right: 2rem;
        margin-top: 1rem;
        opacity: 0.7;
    }
    .filter:hover{
        opacity: 1;
    }
    .filter-active {
        opacity: 1 !important;
        border-bottom: 2px solid #222;
        padding-bottom: 4px;
    }
    .filter p{
        font-size: 0.8rem;
    }
    .tax-info{
        display: none;
    }
    .tax-toogle{
        border: 1px solid black;
        border-radius: 1rem;
        height: 3.5rem;
        padding: 1rem;
        margin-left: 2rem;
        display: flex;
        align-items: center;
    }
</style>
<div id="filters">
<div class="filter" data-category="trending">
  <div><i class="fa-solid fa-fire"></i></div>
  <p>Trending</p>
</div>
<div class="filter" data-category="rooms">
  <div><i class="fa-solid fa-hotel"></i></div>
  <p>Rooms</p>
</div>
<div class="filter" data-category="iconic_cities">
  <div><i class="fa-solid fa-city"></i></div>
  <p>Iconic cities</p>
</div>
<div class="filter" data-category="mountains">
  <div><i class="fa-solid fa-mountain-city"></i></div>
  <p>Mountains</p>
</div>
<div class="filter" data-category="castles">
  <div><i class="fa-solid fa-brands fa-fort-awesome"></i></div>
  <p>Castles</p>
</div>
<div class="filter" data-category="arctic">
  <div><i class="fa-regular fa-snowflake"></i></div>
  <p>Arctic</p>
</div>
<div class="filter" data-category="camping">
  <div><i class="fa-solid fa-campground"></i></div>
  <p>Camping</p>
</div>
<div class="filter" data-category="farms">
  <div><i class="fa-solid fa-tractor"></i></div>
  <p>Farms</p>
</div>
<div class="filter" data-category="homes">
  <div><i class="fa-solid fa-house"></i></div>
  <p>Homes</p>
</div>
<div class="filter" data-category="boats">
  <div><i class="fa-solid fa-sailboat"></i></div>
  <p>Boats</p>
</div>
<div class="filter" data-category="domes">
  <div><i class="fa-solid fa-igloo"></i></div>
  <p>Domes</p>
</div>
<div class="filter" data-category="beaches">
  <div><i class="fa-solid fa-umbrella-beach"></i></div>
  <p>Beaches</p>
</div>


<div class="tax-toogle">
    <div class="form-check-reverse form-switch">
  <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault">
  <label class="form-check-label" for="flexSwitchCheckDefault">Display total after taxes</label>
</div>
</div>
</div>


<div class="row row-cols-lg-4 row-cols-md-3 row-cols-sm-1 g-3 mt-3">

<% for (let listing of allListings) { %>
    <div class="col listing-col" data-category="<%= listing.category || 'homes' %>">
        <a href="/listings/<%= listing._id %>" class="text-decoration-none text-dark">
            <div class="card col listing-card">

                <!-- Optimized Image with Lazy Loading + Blur-up Placeholder -->
                <div class="img-lazy-wrapper">
                  <img
                    src="<%= listing.optimizedImage.placeholder %>"
                    data-src="<%= listing.optimizedImage.src %>"
                    class="card-img-top lazy-img"
                    alt="<%= listing.title %>"
                    loading="lazy"
                    decoding="async"
                    style="height:20rem; object-fit: cover;"
                    onerror="this.src='https://positiwise.com/blog/wp-content/uploads/2022/01/javascript-framework-2.jpg'"
                  >
                </div>

                <% if (listing.isSurge) { %>
                  <span class="price-badge surge-badge">
                    <i class="fa-solid fa-bolt"></i> Surge
                  </span>
                <% } else if (listing.isDiscount) { %>
                  <span class="price-badge discount-badge">
                    <i class="fa-solid fa-tag"></i> Deal
                  </span>
                <% } %>

                <div class="card-body">
                    <p class="card-text">
                        <strong><%= listing.title %></strong> <br/>
                        <% if (listing.dynamicPrice !== listing.price) { %>
                          <span class="dynamic-price">₹<%= Number(listing.dynamicPrice).toLocaleString("en-IN") %></span>
                          <span class="base-price-strike">₹<%= Number(listing.price).toLocaleString("en-IN") %></span>
                          <span class="price-multiplier">×<%= listing.priceMultiplier %></span>
                        <% } else { %>
                          ₹<%= Number(listing.price).toLocaleString("en-IN") %>
                        <% } %>
                        <i class="tax-info">&nbsp +18% GST</i>
                    </p>
                </div>

            </div>
        </a>
    </div>
<% } %>

</div>


<script>
    let taxSwitch=document.getElementById("flexSwitchCheckDefault")
    taxSwitch.addEventListener("click",()=>{
let taxInfo=document.getElementsByClassName("tax-info")

for(info of taxInfo){
    if(info.style.display != "inline"){
        info.style.display="inline"
    }else{
         info.style.display="none"
    }
}
    })
</script>

<!-- CATEGORY FILTER -->
<script>
(function() {
  const filters = document.querySelectorAll(".filter[data-category]");
  const listings = document.querySelectorAll(".listing-col");
  let activeCategory = null;

  filters.forEach(filter => {
    filter.style.cursor = "pointer";

    filter.addEventListener("click", function() {
      const category = this.dataset.category;

      // Toggle: click same filter again to show all
      if (activeCategory === category) {
        activeCategory = null;
        showAll();
        removeActiveState();
        return;
      }

      activeCategory = category;

      // Set active state
      removeActiveState();
      this.classList.add("filter-active");

      // Filter listings
      if (category === "trending") {
        // Trending: show all but sorted (already sorted by default)
        showAll();
      } else {
        listings.forEach(listing => {
          if (listing.dataset.category === category) {
            listing.style.display = "";
          } else {
            listing.style.display = "none";
          }
        });
      }
    });
  });

  function showAll() {
    listings.forEach(listing => {
      listing.style.display = "";
    });
  }

  function removeActiveState() {
    filters.forEach(f => f.classList.remove("filter-active"));
  }
})();
</script>

<!-- LAZY LOADING with Intersection Observer -->
<script>
(function() {
  // Intersection Observer for lazy loading images
  const lazyImages = document.querySelectorAll(".lazy-img");

  if ("IntersectionObserver" in window) {
    const imageObserver = new IntersectionObserver((entries, observer) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const img = entry.target;
          const src = img.dataset.src;

          if (src) {
            // Create a new image to preload
            const preloader = new Image();
            preloader.onload = function() {
              img.src = src;
              img.classList.add("lazy-loaded");
              img.classList.remove("lazy-img");
            };
            preloader.src = src;
          }

          observer.unobserve(img);
        }
      });
    }, {
      rootMargin: "200px 0px", // Start loading 200px before visible
      threshold: 0.01,
    });

    lazyImages.forEach((img) => imageObserver.observe(img));
  } else {
    // Fallback: load all images immediately
    lazyImages.forEach((img) => {
      if (img.dataset.src) {
        img.src = img.dataset.src;
        img.classList.add("lazy-loaded");
      }
    });
  }
})();
</script>