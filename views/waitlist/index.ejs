<% layout("/layouts/boilerplate") %>

<div class="row">
  <div class="col-10 offset-1">
    <h3 class="mt-3 mb-4">
      <i class="fa-solid fa-clock-rotate-left me-2"></i>My Waitlist
    </h3>

    <% if (entries.length === 0) { %>
      <div class="text-center py-5">
        <i class="fa-solid fa-hourglass-empty" style="font-size: 3rem; color: #ccc;"></i>
        <h5 class="mt-3">No waitlist entries</h5>
        <p class="text-muted">When a listing you want is fully booked, join the waitlist to get notified if it opens up.</p>
        <a href="/listings" class="btn btn-dark"><i class="fa-solid fa-compass me-1"></i> Browse Listings</a>
      </div>
    <% } else { %>
      <div class="row g-3">
        <% for (let entry of entries) { %>
          <div class="col-md-6">
            <div class="card waitlist-card">
              <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                  <div>
                    <h6><%= entry.listing?.title || "Listing" %></h6>
                    <small class="text-muted">
                      <i class="fa-solid fa-location-dot"></i>
                      <%= entry.listing?.location || "" %>
                    </small>
                  </div>
                  <span class="badge <%= entry.status === 'notified' ? 'bg-success' : 'bg-secondary' %>">
                    <% if (entry.status === 'waiting') { %>
                      #<%= entry.position %> in queue
                    <% } else if (entry.status === 'notified') { %>
                      🎉 Slot Available!
                    <% } %>
                  </span>
                </div>

                <div class="mt-2">
                  <small>
                    <i class="fa-solid fa-calendar"></i>
                    <%= new Date(entry.checkIn).toLocaleDateString("en-IN", { day: "numeric", month: "short" }) %>
                    –
                    <%= new Date(entry.checkOut).toLocaleDateString("en-IN", { day: "numeric", month: "short", year: "numeric" }) %>
                  </small>
                </div>

                <% if (entry.status === 'notified' && entry.expiresAt) { %>
                  <div class="alert alert-success py-2 mt-2 mb-0">
                    <strong>Your turn!</strong> Book before
                    <%= new Date(entry.expiresAt).toLocaleTimeString("en-IN", { hour: "2-digit", minute: "2-digit" }) %>
                    <a href="/listings/<%= entry.listing?._id %>" class="btn btn-sm btn-success ms-2">Book Now</a>
                  </div>
                <% } %>

                <div class="mt-2">
                  <% if (entry.status === 'notified') { %>
                    <a href="/listings/<%= entry.listing?._id %>" class="btn btn-sm btn-danger">Book Now</a>
                  <% } %>
                  <form action="/api/waitlist/<%= entry._id %>/leave" method="POST" style="display:inline;">
                    <button class="btn btn-sm btn-outline-secondary">Leave Waitlist</button>
                  </form>
                </div>
              </div>
            </div>
          </div>
        <% } %>
      </div>
    <% } %>
  </div>
</div>
