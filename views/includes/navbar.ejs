<% const user = typeof currUser !== "undefined" ? currUser : null; %>

<nav class="navbar navbar-expand-md bg-body-light border-bottom sticky-top">
  <div class="container-fluid">

    <!-- Brand -->
    <a class="navbar-brand" href="/listings">
      <i class="fa-solid fa-compass"></i>
    </a>

    <!-- Toggle -->
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- Navbar content -->
    <div class="collapse navbar-collapse" id="navbarNav">

      <!-- Left links -->
      <ul class="navbar-nav me-3">
        <li class="nav-item">
          <a class="nav-link" href="/listings">Explore</a>
        </li>
      </ul>

      <!-- SEARCH BAR -->
      <form class="d-flex ms-auto" role="search">
        <input
          class="form-control me-2 text-center"
          type="search"
          placeholder="Search destinations"
          style="border-radius: 25px; font-size: 1rem; padding: 0.8rem 1rem; height: 45px;"
        >

        <button
          class="btn btn-danger d-flex align-items-center"
          style="border-radius: 25px; padding: 0.7rem 1.2rem;"
          type="submit"
        >
          <i class="fa-solid fa-magnifying-glass me-2"></i>
          Search
        </button>
      </form>

      <!-- Right links -->
      <ul class="navbar-nav ms-auto">
        <li class="nav-item">
          <a class="nav-link" href="/listings/new">Airbnb your home</a>
        </li>

        <% if (!user) { %>
          <li class="nav-item">
            <a class="nav-link" href="/login"><b>Log in</b></a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/signup"><b>Sign Up</b></a>
          </li>
        <% } %>

        <% if (user) { %>
          <li class="nav-item">
            <a class="nav-link" href="/logout"><b>Log Out</b></a>
          </li>
        <% } %>
      </ul>

    </div>
  </div>
</nav>
