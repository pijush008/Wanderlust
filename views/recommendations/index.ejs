<% layout("/layouts/boilerplate") %>

<div class="recommendations-page">
  <div class="text-center mt-3 mb-4">
    <h3><i class="fa-solid fa-wand-magic-sparkles me-2"></i>Recommended For You</h3>
    <p class="text-muted">
      <% if (method === "hybrid") { %>
        Personalized picks based on your browsing and booking history
      <% } else if (method === "collaborative") { %>
        Travelers with similar taste also loved these
      <% } else { %>
        Popular listings on Wanderlust
      <% } %>
    </p>
    <small class="text-muted">
      <span class="badge bg-light text-dark">
        <i class="fa-solid fa-brain me-1"></i><%= method %> filtering
      </span>
    </small>
  </div>

  <% if (recommendations.length === 0) { %>
    <div class="text-center py-5">
      <i class="fa-solid fa-compass" style="font-size: 3rem; color: #ccc;"></i>
      <h5 class="mt-3">No recommendations yet</h5>
      <p class="text-muted">Browse and book some listings — we'll learn your preferences!</p>
      <a href="/listings" class="btn btn-danger">
        <i class="fa-solid fa-compass me-1"></i> Start Exploring
      </a>
    </div>
  <% } else { %>
    <div class="row row-cols-lg-4 row-cols-md-3 row-cols-sm-1 g-3">
      <% for (let rec of recommendations) { %>
        <div class="col">
          <a href="/listings/<%= rec._id %>" class="text-decoration-none text-dark">
            <div class="card listing-card rec-card">
              <img
                src="<%= rec.image || '' %>"
                class="card-img-top"
                alt="<%= rec.title %>"
                style="height: 18rem; object-fit: cover;"
                loading="lazy"
                onerror="this.src='https://positiwise.com/blog/wp-content/uploads/2022/01/javascript-framework-2.jpg'"
              >

              <!-- Recommendation reason badge -->
              <div class="rec-reason">
                <i class="fa-solid fa-sparkles me-1"></i><%= rec.reason %>
              </div>

              <div class="card-body">
                <strong><%= rec.title %></strong><br>
                <small class="text-muted">
                  <i class="fa-solid fa-location-dot"></i> <%= rec.location %>
                </small>
                <div class="mt-1">
                  <% if (rec.dynamicPrice && rec.dynamicPrice !== rec.price) { %>
                    <span class="dynamic-price">₹<%= Number(rec.dynamicPrice).toLocaleString("en-IN") %></span>
                    <span class="base-price-strike">₹<%= Number(rec.price).toLocaleString("en-IN") %></span>
                  <% } else { %>
                    <strong>₹<%= Number(rec.price).toLocaleString("en-IN") %></strong>
                  <% } %>
                  <span class="text-muted">/night</span>
                </div>

                <!-- Score indicator -->
                <div class="rec-score mt-1">
                  <div class="rec-score-bar">
                    <div class="rec-score-fill" style="width: <%= Math.min(rec.score, 100) %>%"></div>
                  </div>
                  <small class="text-muted"><%= rec.score %>% match</small>
                </div>
              </div>
            </div>
          </a>
        </div>
      <% } %>
    </div>
  <% } %>
</div>
