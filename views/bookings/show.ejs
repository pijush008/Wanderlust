<% layout("/layouts/boilerplate") %>

<div class="row">
  <div class="col-8 offset-2">

    <!-- Booking Confirmation Header -->
    <div class="booking-confirmation text-center mt-4 mb-4">
      <% if (booking.status === "confirmed") { %>
        <div class="confirmation-icon">
          <i class="fa-solid fa-circle-check" style="font-size: 4rem; color: #28a745;"></i>
        </div>
        <h2 class="mt-3">Booking Confirmed!</h2>
        <p class="text-muted">Your reservation has been secured</p>
      <% } else if (booking.status === "cancelled") { %>
        <div class="confirmation-icon">
          <i class="fa-solid fa-circle-xmark" style="font-size: 4rem; color: #dc3545;"></i>
        </div>
        <h2 class="mt-3">Booking Cancelled</h2>
        <p class="text-muted"><%= booking.cancelReason || "This booking has been cancelled" %></p>
      <% } else { %>
        <div class="confirmation-icon">
          <i class="fa-solid fa-clock" style="font-size: 4rem; color: #ffc107;"></i>
        </div>
        <h2 class="mt-3">Booking <%= booking.status %></h2>
      <% } %>
    </div>

    <!-- Booking Details Card -->
    <div class="card mb-4">
      <div class="card-body">
        <div class="row">
          <!-- Listing Info -->
          <div class="col-md-4">
            <img
              src="<%= booking.listing.image?.url || '' %>"
              class="img-fluid rounded"
              alt="<%= booking.listing.title %>"
              style="height: 150px; width: 100%; object-fit: cover;"
            >
          </div>
          <div class="col-md-8">
            <h4><%= booking.listing.title %></h4>
            <p class="text-muted">
              <i class="fa-solid fa-location-dot"></i>
              <%= booking.listing.location %>, <%= booking.listing.country %>
            </p>

            <div class="row mt-3">
              <div class="col-6">
                <small class="text-muted">Check-in</small>
                <p class="fw-bold"><%= new Date(booking.checkIn).toLocaleDateString("en-IN", { weekday: "short", day: "numeric", month: "short", year: "numeric" }) %></p>
              </div>
              <div class="col-6">
                <small class="text-muted">Check-out</small>
                <p class="fw-bold"><%= new Date(booking.checkOut).toLocaleDateString("en-IN", { weekday: "short", day: "numeric", month: "short", year: "numeric" }) %></p>
              </div>
            </div>

            <p><i class="fa-solid fa-user"></i> <%= booking.guests %> guest(s) · <%= booking.pricing.nights %> night(s)</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Pricing Breakdown -->
    <div class="card mb-4">
      <div class="card-body">
        <h5><i class="fa-solid fa-receipt me-2"></i>Price Breakdown</h5>
        <table class="table table-sm table-borderless mt-3">
          <tbody>
            <tr>
              <td>Base price per night</td>
              <td class="text-end">₹<%= Number(booking.pricing.basePrice).toLocaleString("en-IN") %></td>
            </tr>
            <tr>
              <td>Dynamic price per night <span class="badge bg-secondary">×<%= booking.pricing.multiplier %></span></td>
              <td class="text-end">₹<%= Number(booking.pricing.dynamicPrice).toLocaleString("en-IN") %></td>
            </tr>
            <tr>
              <td>× <%= booking.pricing.nights %> nights</td>
              <td class="text-end"></td>
            </tr>
            <tr class="border-top fw-bold">
              <td>Total</td>
              <td class="text-end">₹<%= Number(booking.pricing.totalAmount).toLocaleString("en-IN") %></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Booking ID & Meta -->
    <div class="card mb-4">
      <div class="card-body">
        <small class="text-muted">
          Booking ID: <code><%= booking._id %></code><br>
          Booked on: <%= new Date(booking.createdAt).toLocaleString("en-IN") %><br>
          <% if (booking.confirmedAt) { %>
            Confirmed at: <%= new Date(booking.confirmedAt).toLocaleString("en-IN") %>
          <% } %>
        </small>
      </div>
    </div>

    <!-- Actions -->
    <div class="d-flex gap-2 mb-4">
      <a href="/bookings" class="btn btn-outline-dark">
        <i class="fa-solid fa-arrow-left me-1"></i> My Bookings
      </a>
      <% if (booking.status === "confirmed" && booking.guest._id.toString() === currUser._id.toString()) { %>
        <form action="/bookings/<%= booking._id %>/cancel" method="POST" style="display:inline;"
          onsubmit="return confirm('Are you sure you want to cancel this booking?')">
          <input type="hidden" name="reason" value="Cancelled by guest">
          <button class="btn btn-outline-danger">
            <i class="fa-solid fa-ban me-1"></i> Cancel Booking
          </button>
        </form>
      <% } %>
    </div>

  </div>
</div>
