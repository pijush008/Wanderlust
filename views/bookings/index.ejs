<% layout("/layouts/boilerplate") %>

<div class="row">
  <div class="col-10 offset-1">

    <h3 class="mt-3 mb-4">
      <i class="fa-solid fa-calendar-check me-2"></i>My Bookings
    </h3>

    <% if (bookings.length === 0) { %>
      <div class="text-center py-5">
        <i class="fa-solid fa-suitcase" style="font-size: 3rem; color: #ccc;"></i>
        <h5 class="mt-3">No bookings yet</h5>
        <p class="text-muted">Start exploring and book your next adventure!</p>
        <a href="/listings" class="btn btn-dark">
          <i class="fa-solid fa-compass me-1"></i> Explore Listings
        </a>
      </div>
    <% } else { %>
      <div class="row g-3">
        <% for (let booking of bookings) { %>
          <div class="col-md-6">
            <div class="card booking-card">
              <div class="row g-0">
                <div class="col-4">
                  <img
                    src="<%= booking.listing?.image?.url || '' %>"
                    class="img-fluid rounded-start h-100"
                    style="object-fit: cover;"
                    alt="listing"
                  >
                </div>
                <div class="col-8">
                  <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                      <h6 class="card-title mb-1"><%= booking.listing?.title || "Deleted Listing" %></h6>
                      <span class="badge
                        <%= booking.status === 'confirmed' ? 'bg-success' :
                           booking.status === 'cancelled' ? 'bg-danger' :
                           booking.status === 'completed' ? 'bg-info' : 'bg-warning' %>
                      "><%= booking.status %></span>
                    </div>
                    <small class="text-muted">
                      <%= new Date(booking.checkIn).toLocaleDateString("en-IN", { day: "numeric", month: "short" }) %>
                      –
                      <%= new Date(booking.checkOut).toLocaleDateString("en-IN", { day: "numeric", month: "short", year: "numeric" }) %>
                    </small>
                    <p class="mb-1 mt-2">
                      <strong>₹<%= Number(booking.pricing.totalAmount).toLocaleString("en-IN") %></strong>
                      · <%= booking.pricing.nights %> night(s)
                    </p>
                    <a href="/bookings/<%= booking._id %>" class="btn btn-sm btn-outline-dark mt-1">View Details</a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        <% } %>
      </div>
    <% } %>

  </div>
</div>
